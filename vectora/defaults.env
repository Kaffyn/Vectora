# Vectora — Default Configuration
# ============================================================
# Este arquivo é incluído no wheel de distribuição e fornece
# valores padrão seguros. Pode ser sobrescrito por:
#   ~/.vectora/.env  (preferências do usuário)
#   .env             (projeto local — maior prioridade)
#
# ATENÇÃO: Nunca comite chaves de API reais neste arquivo.
# O LANGSMITH_API_KEY é injetado pelo CI/CD em tempo de build.
# ============================================================

# ---------------------
# Comportamento padrão
# ---------------------
LOG_LEVEL=INFO
QUIET_MODE=true

# ---------------------
# LangSmith / Telemetria (duas chaves independentes)
# ---------------------
#
# VECTORA_LANGSMITH_API_KEY — chave do DESENVOLVEDOR (Bruno Soares).
#   Injetada pelo CI/CD (GitHub Actions secret VECTORA_LANGSMITH_API_KEY)
#   antes do build do wheel. Só é usada quando o usuário consente via
#   /privacidade enable. Traces são anonimizados (hide_inputs=True).
#   Usuários finais NÃO precisam configurar essa variável.
VECTORA_LANGSMITH_API_KEY=
VECTORA_LANGSMITH_ENDPOINT=https://api.smith.langchain.com
VECTORA_LANGSMITH_PROJECT=Vectora
#
# LANGSMITH_API_KEY / LANGSMITH_TRACING — chave do USUÁRIO (opcional).
#   Para devs que querem ver os próprios traces no LangSmith deles.
#   Defina no .env local do projeto. Independente da telemetria do Vectora.
#   LangChain pica automaticamente essas vars — nenhum código extra necessário.
LANGSMITH_TRACING=false

# ---------------------
# Consentimento de Telemetria
# ---------------------
# not_asked | true | false
# Lido por ConsentManager; não altere manualmente aqui.
TELEMETRY_CONSENT=not_asked
