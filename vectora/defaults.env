LLM_PROVIDER=google-genai
LLM_TEMPERATURE=0.2
ENABLE_WEB_SEARCH=true
ENABLE_WEB_FETCH=true
ENABLE_FILE_OPERATIONS=true
ENABLE_MCP=true
ENABLE_RAG=true
RAG_SEARCH_TOP_K=10
RAG_SEARCH_MIN_SCORE=0.5
RERANKER_TYPE=voyage
RERANKER_MODEL=reranker-2-lite
RAG_RERANKER_TOP_K=5
LOG_LEVEL=INFO
LOG_JSON=false

# MCP Configuration
MCP_TRANSPORT_TYPE=stdio
MCP_COMMAND=uv
MCP_COMMAND_ARGS=["run", "vectora-mcp"]
