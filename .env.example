# ============================================================================
# VECTORA ENVIRONMENT CONFIGURATION — LOCAL-FIRST MVP
# ============================================================================
# Copie este arquivo para .env e preencha com suas chaves.
# Toda a infraestrutura é file-based: nenhum container é necessário.
# ============================================================================

# LLM Provider (escolha um)
LLM_PROVIDER=google-genai
GOOGLE_API_KEY=AIza_your_key_here
GOOGLE_MODEL=gemini-2.0-flash

# Alternativas:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_MODEL=gpt-4o

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# ANTHROPIC_MODEL=claude-opus-4-5

LLM_TEMPERATURE=0.2

# ============================================================================
# RAG — Vector Store: LanceDB (file-based, zero-config)
# ============================================================================
LANCEDB_DIR=./data/lancedb

# Embeddings via Voyage AI (necessário para RAG)
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-4
EMBEDDING_DIMS=1024
ENABLE_RAG=true

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
LOG_JSON=false

# ============================================================================
# Ferramentas do Agente
# ============================================================================
ENABLE_WEB_SEARCH=true
ENABLE_WEB_FETCH=true
ENABLE_FILE_OPERATIONS=true
ENABLE_MCP=false
