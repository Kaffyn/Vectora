# ============================================================================
# VECTORA ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in the required values
# DO NOT commit .env to version control (it's in .gitignore)

# ============================================================================
# 1. LLM & AI PROVIDERS
# ============================================================================

# LLM Provider Selection (Default: google-genai)
# Options: google-genai, ollama, openai, anthropic
LLM_PROVIDER="google-genai"

# Common LLM Settings
LLM_TEMPERATURE="0.2"  # 0.0 (deterministic) to 2.0 (creative)

# ---- Google Gemini (Default) ----
# Get your API key from: https://ai.google.dev
GOOGLE_API_KEY="AIza..."
GOOGLE_MODEL="gemini-2.0-flash"  # Options: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash

# ---- Ollama (Local LLMs) ----
# Make sure Ollama is running: ollama serve
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# OLLAMA_MODEL="gpt-oss:20b"

# ---- OpenAI (GPT Models) ----
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o"

# ---- Anthropic Claude ----
# Get your API key from: https://console.anthropic.com
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-opus-4-1"

# VoyageAI for Embeddings and Reranking (Required for RAG)
# Get your API key from: https://www.voyageai.com
VOYAGE_API_KEY="your_voyage_api_key_here"

# ============================================================================
# 2. DATABASE - PostgreSQL (Recommended for Production)
# ============================================================================

# PostgreSQL Connection
# Format: postgresql://user:password@host:port/database
# Example: postgresql://vectora:secretpass@localhost:5432/vectora
POSTGRES_USER="vectora"
POSTGRES_PASSWORD="your_secure_postgres_password_here"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="vectora"
PGDATA="/var/lib/postgresql/18/docker"

# Constructed DSN (used by LangGraph checkpointer)
DB_DSN="postgresql://vectora:your_secure_postgres_password_here@localhost:5432/vectora"

# Alternative: SQLite for Development
# DATABASE_URL="sqlite:///./vectora.db"

# ============================================================================
# 3. VECTOR STORES - Choose One
# ============================================================================

# LanceDB Configuration (Default - File-based)
# Recommended for MVP and development
VECTOR_STORE_TYPE="lancedb"
LANCEDB_DIR="./data/lancedb"

# OR: Qdrant Configuration (Production)
# Requires: docker run -p 6333:6333 qdrant/qdrant
# VECTOR_STORE_TYPE="qdrant"
# QDRANT_URL="http://localhost:6333"
# QDRANT_API_KEY=""  # if using Qdrant Cloud

# ============================================================================
# 4. SEMANTIC CACHING - Valkey (Redis)
# ============================================================================

# Valkey Configuration (In-Memory Cache for Semantic Caching)
# Requires: docker run -p 6379:6379 valkey/valkey:latest
VALKEY_HOST="localhost"
VALKEY_PORT="6379"
VALKEY_DB="0"
VALKEY_PASSWORD=""  # Leave empty if no password, or set your password
VALKEY_URL="redis://localhost:6379/0"

# Cache Configuration
CACHE_TTL="3600"  # Cache time-to-live in seconds (1 hour)
ENABLE_SEMANTIC_CACHING="true"

# ============================================================================
# 5. LOGGING & OBSERVABILITY
# ============================================================================

LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_JSON="false"  # Set to "true" for JSON structured logging
LOG_FILE="logs/vectora.jsonl"

# ============================================================================
# 6. COMMUNITY TOOLS CONFIGURATION
# ============================================================================

# Web Search Tool (DuckDuckGo - Free)
ENABLE_WEB_SEARCH="true"

# Web Fetch Tool (URL Reader)
ENABLE_WEB_FETCH="true"
WEB_FETCH_MAX_SIZE="5000"  # Max characters to fetch from URLs
WEB_FETCH_ALLOWED_DOMAINS=""  # Comma-separated whitelist (optional, empty = all)

# Database Tools (SQL Query Execution)
ENABLE_DATABASE="false"  # Opt-in for security
DATABASE_URL=""  # e.g., sqlite:///vectora.db or postgresql://...
DATABASE_ALLOWED_TABLES=""  # Comma-separated whitelist (optional)

# MCP Server Integration (Future)
# ENABLE_MCP="false"
# MCP_SERVER_URL=""  # e.g., ws://localhost:5000

# ============================================================================
# 7. GITHUB CONFIGURATION (For Docker Deployment)
# ============================================================================

# GitHub Token (for Docker image pulls from ghcr.io)
# Get your token from: https://github.com/settings/tokens
# Required scopes: read:packages, read:user
GITHUB_TOKEN="your_github_token_here"

# GitHub Container Registry Authentication
# Format: ghcr.io/your_username/vectora:latest
GHCR_USERNAME="your_github_username"

# ============================================================================
# 8. DOCKER & DEPLOYMENT
# ============================================================================

# Docker Compose Network
COMPOSE_PROJECT_NAME="vectora"
NETWORK_NAME="vectora_network"

# API Server Configuration
API_HOST="0.0.0.0"
API_PORT="8000"

# Python Runtime
PYTHON_VERSION="3.14.5"

# ============================================================================
# 9. DEVELOPMENT & DEBUG
# ============================================================================

# FastAPI Debug Mode
DEBUG="false"  # Set to "true" for development only

# Environment
ENVIRONMENT="production"  # development, staging, production

# ============================================================================
# 10. OPTIONAL - Advanced Configuration
# ============================================================================

# Ollama Configuration (if using local LLMs)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="gpt-oss:20b"

# Timeout Settings
REQUEST_TIMEOUT="30"  # seconds
GRAPH_EXECUTION_TIMEOUT="300"  # seconds

# Rate Limiting
ENABLE_RATE_LIMITING="true"
REQUESTS_PER_MINUTE="60"

# ============================================================================
# 11. RAG — Embedding + Vector Search + Reranking (Phase 4)
# ============================================================================

# Embedding (Voyage AI 4)
VOYAGE_API_KEY="pa-seu_token_voyage"
EMBEDDING_MODEL="voyage-4"  # voyage-4, voyage-4-lite, voyage-code-3, etc
EMBEDDING_DIMS="1024"

# Embedding Queue (Fallback quando Voyage API falha)
EMBEDDING_QUEUE_ENABLED="true"
EMBEDDING_QUEUE_DB="sqlite:///./data/embedding_queue.db"

# Vector Store (Qdrant)
QDRANT_URL="http://vectora-qdrant:6333"
QDRANT_API_KEY=""  # Leave empty for local VPS setup

# Vector Search Configuration
RAG_SEARCH_TOP_K="10"        # Raw results before reranking
RAG_SEARCH_MIN_SCORE="0.5"   # Min similarity threshold

# Qdrant Collections (múltiplas coleções por tipo)
QDRANT_COLLECTIONS="articles,wiki,api_docs,knowledge_base"

# Reranking (BM25 local ou Voyage AI)
RERANKER_TYPE="bm25"  # "bm25" (MVP, sem API) ou "voyage" (produção)
RERANKER_MODEL="reranker-2.5-large"  # Options: reranker-2.5-large, reranker-2.5-mbxl
RAG_RERANKER_TOP_K="5"  # Final results after reranking

# ============================================================================
# NOTES FOR SETUP
# ============================================================================
#
# 1. Start PostgreSQL:
#    docker run --name vectora-postgres \
#      -e POSTGRES_USER=vectora \
#      -e POSTGRES_PASSWORD=your_password \
#      -e POSTGRES_DB=vectora \
#      -p 5432:5432 \
#      -d postgres:18
#
# 2. Start Valkey:
#    docker run --name vectora-valkey \
#      -p 6379:6379 \
#      -d valkey/valkey:latest
#
# 3. Start Qdrant (optional, instead of LanceDB):
#    docker run --name vectora-qdrant \
#      -p 6333:6333 \
#      -d qdrant/qdrant
#
# 4. Initialize database:
#    uv run src/main.py --init-db
#
# 5. Run Vectora:
#    uv run src/main.py
#
# ============================================================================
