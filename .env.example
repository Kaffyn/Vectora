# Vectora Environment Configuration (Local Development)

# LLM Provider (google-genai, openai, anthropic, ollama)
LLM_PROVIDER=google-genai

# Google Gemini API
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-3.0-flash

# OpenAI (se usar)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic (se usar)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-1

# Ollama (local)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gpt-oss:20b

# Embedding & RAG
VOYAGE_API_KEY=pa-...
EMBEDDING_MODEL=voyage-3

# Vector Store (lancedb ou qdrant)
VECTOR_STORE_TYPE=lancedb
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...

# Database (SQLite por padrão, ou PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost/vectora

# Observability
LANGSMITH_API_KEY=ls-...
LOG_LEVEL=INFO
LOG_JSON=false

# MCP Configuration
ENABLE_MCP=true
# MCP_SERVER_URL=http://localhost:8000
# MCP_COMMAND=python -m mcp.server src/mcp_server.py

# Web Search
ENABLE_WEB_SEARCH=true

# RAG
ENABLE_RAG=true

# File Operations
ENABLE_FILE_OPERATIONS=true

# Tool Safety
ENABLE_TOOL_SAFETY=true

# Temperature for LLM
LLM_TEMPERATURE=0.2

# Dev/Prod
NODE_ENV=development
