# ============================================================================
# VECTORA ENVIRONMENT CONFIGURATION - DEVELOPMENT
# ============================================================================

# LLM Provider
LLM_PROVIDER=google-genai
GOOGLE_API_KEY=AIza_test_key_change_this
GOOGLE_MODEL=gemini-3.0-flash
LLM_TEMPERATURE=0.2

# Database (SQLite para desenvolvimento)
DB_DSN=sqlite:///./vectora.db

# Vector Store (LanceDB para desenvolvimento)
VECTOR_STORE_TYPE=lancedb
LANCEDB_DIR=./data/lancedb

# Cache
VALKEY_URL=redis://localhost:6379/0
ENABLE_SEMANTIC_CACHING=false

# RAG
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-4
EMBEDDING_DIMS=1024

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Tools
ENABLE_WEB_SEARCH=true
ENABLE_WEB_FETCH=true
ENABLE_DATABASE=false
ENABLE_MCP=false

# API
API_HOST=0.0.0.0
API_PORT=8000
