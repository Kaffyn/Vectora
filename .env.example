ANTHROPIC_API_KEY="ESSA É A ANTHROPIC_API_KEY"
OPENAI_API_KEY="ESSA É A OPENAI_API_KEY"
GOOGLE_API_KEY="ESSA É A GOOGLE_API_KEY"

POSTGRES_USER="USUARIO_DA_BASE_DE_DADOS"
POSTGRES_PASSWORD="SENHA_BASE_DE_DADOS"
POSTGRES_DB="NOME_BASE_DE_DADOS"
PGDATA=/var/lib/postgresql/18/docker

DB_DNS='postgresql://USUARIO_DA_BASE_DE_DADOS:SENHA_BASE_DE_DADOS@localhost:5432/NOME_BASE_DE_DADOS'

# Logging Configuration
LOG_LEVEL="INFO"
LOG_JSON="false"
LOG_FILE="logs/vectora.jsonl"

# Tool Configuration
ENABLE_WEB_SEARCH="true"
ENABLE_WEB_FETCH="true"
ENABLE_DATABASE="false"
WEB_FETCH_MAX_SIZE="5000"
WEB_FETCH_ALLOWED_DOMAINS=""  # comma-separated list (optional)
DATABASE_URL=""  # e.g., sqlite:///vectora.db or postgresql://...
DATABASE_ALLOWED_TABLES=""  # comma-separated list (optional)

# MCP Configuration (Future)
# ENABLE_MCP="false"
# MCP_SERVER_URL=""  # e.g., ws://localhost:5000
