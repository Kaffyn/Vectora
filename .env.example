LLM_PROVIDER=google-genai
GOOGLE_API_KEY=your-google-api-key-here
TAVILY_API_KEY=tvly-...

# ============================================================================
# RAG - Embedding & Vector Search (OBRIGATÓRIO para RAG)
# ============================================================================
# Voyage AI para embeddings
# Obtenha em: https://www.voyageai.com/api
VOYAGE_API_KEY=pa-...

# Vector Store tipo (padrão: lancedb para development)
VECTOR_STORE_TYPE=lancedb

# ============================================================================
# OBSERVABILITY (OPCIONAL)
# ============================================================================
# LangSmith para rastreamento de execução (auto-injetado via SDK)
# Obtenha em: https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=vectora

LOG_LEVEL=INFO
