# Vectora MVP - Configuração de Ambiente
# Copie este arquivo para .env e configure com suas credenciais

# ============================================================================
# LLM PROVIDER (OBRIGATÓRIO)
# ============================================================================
# Escolha um dos providers: google-genai, openai, anthropic, ollama
# Recomendado: google-genai (gratuito com bons limites)
LLM_PROVIDER=google-genai

# --- Google Gemini (RECOMENDADO) ---
# Obtenha em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# --- OpenAI (alternativa) ---
# OPENAI_API_KEY=sk-...

# --- Anthropic Claude (alternativa) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama Local (alternativa, sem custos) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ============================================================================
# WEB SEARCH - Tavily (OBRIGATÓRIO para web_search tool)
# ============================================================================
# Obtenha em: https://tavily.com/api
TAVILY_API_KEY=tvly-...

# ============================================================================
# RAG - Embedding & Vector Search (OBRIGATÓRIO para RAG)
# ============================================================================
# Voyage AI para embeddings
# Obtenha em: https://www.voyageai.com/api
VOYAGE_API_KEY=pa-...

# Vector Store tipo (padrão: lancedb para development)
VECTOR_STORE_TYPE=lancedb

# ============================================================================
# OBSERVABILITY (OPCIONAL)
# ============================================================================
# LangSmith para rastreamento de execução
# Obtenha em: https://smith.langchain.com
# LANGSMITH_API_KEY=ls-...

LOG_LEVEL=INFO
