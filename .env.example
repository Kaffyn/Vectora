# ============================================================================
# VECTORA — LOCAL-FIRST MVP CONFIGURATION
# ============================================================================
# Copie este arquivo para .env e preencha com suas chaves.
# Toda a infraestrutura é file-based: nenhum container é necessário.
# ============================================================================

# LLM Provider (escolha um)
# Sugestão MVP: ollama (local) ou gemini (nuvem rápida)
LLM_PROVIDER=google-genai
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Alternativas:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

LLM_TEMPERATURE=0.2

# ============================================================================
# RAG — Vector Store: LanceDB (file-based, zero-config)
# ============================================================================
LANCEDB_DIR=./data/lancedb
ENABLE_RAG=true

# Embeddings e Reranking via Voyage AI (Obrigatório para RAG de alta performance)
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3-lite
EMBEDDING_DIMS=512
RERANKER_TYPE=voyage
RERANKER_MODEL=reranker-2-lite

# ============================================================================
# MCP (Model Context Protocol)
# ============================================================================
ENABLE_MCP=false
MCP_SERVER_URL=http://localhost:8001/mcp
MCP_TRANSPORT_TYPE=http
MCP_TIMEOUT=30

# ============================================================================
# Logging e Performance
# ============================================================================
LOG_LEVEL=INFO
LOG_JSON=false
EMBEDDING_QUEUE_ENABLED=true
EMBEDDING_QUEUE_DB=sqlite+aiosqlite:///./data/embedding_queue.db

# ============================================================================
# Ferramentas do Agente
# ============================================================================
ENABLE_WEB_SEARCH=true
ENABLE_WEB_FETCH=true
ENABLE_FILE_OPERATIONS=true
WEB_FETCH_MAX_SIZE=5000
