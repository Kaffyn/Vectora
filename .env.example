# Vectora Environment Configuration
# Copie este arquivo para .env e configure com suas credenciais

# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================
# Escolha um dos providers abaixo: google-genai, openai, anthropic, ollama
# Recomendado: google-genai (gratuito com bons limites)
LLM_PROVIDER=google-genai

# --- Google Gemini (RECOMENDADO - Gratuito) ---
# Obtenha a chave em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-3.0-flash
LLM_TEMPERATURE=0.2

# --- OpenAI ---
# Descomente as linhas abaixo se usar OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# LLM_TEMPERATURE=0.2

# --- Anthropic Claude ---
# Descomente as linhas abaixo se usar Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-1
# LLM_TEMPERATURE=0.2

# --- Ollama (Local, sem custos) ---
# Descomente as linhas abaixo se usar Ollama local
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gpt-oss:20b
# LLM_TEMPERATURE=0.2

# ============================================================================
# EMBEDDING & RAG (OBRIGATÓRIO para RAG)
# ============================================================================
# Voyage AI - Recomendado (gratuito com bons limites)
# Obtenha a chave em: https://www.voyageai.com/api
VOYAGE_API_KEY=pa-...
EMBEDDING_MODEL=voyage-3

# ============================================================================
# VECTOR STORE
# ============================================================================
# Opções: lancedb (local), qdrant (remote)
VECTOR_STORE_TYPE=lancedb

# Se usar Qdrant (comentado por padrão)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=...

# ============================================================================
# DATABASE
# ============================================================================
# SQLite é usado por padrão. Descomente para PostgreSQL em produção
# DATABASE_URL=postgresql://user:password@localhost/vectora

# ============================================================================
# OBSERVABILITY
# ============================================================================
# LangSmith API (opcional) para rastreamento de execução
# Obtenha em: https://smith.langchain.com
LANGSMITH_API_KEY=ls-...
LOG_LEVEL=INFO
LOG_JSON=false

# ============================================================================
# FEATURES
# ============================================================================
# Busca na web (requer internet)
ENABLE_WEB_SEARCH=true

# RAG (Retrieval-Augmented Generation - requer VOYAGE_API_KEY)
ENABLE_RAG=true

# Operações com arquivos (read, edit, grep, terminal)
ENABLE_FILE_OPERATIONS=true

# Validação de segurança para tools
ENABLE_TOOL_SAFETY=true

# ============================================================================
# MCP (Model Context Protocol)
# ============================================================================
ENABLE_MCP=true
# MCP_SERVER_URL=http://localhost:8000
# MCP_COMMAND=python -m mcp.server src/mcp_server.py

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=development

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="Vectora"
