{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${input:github_mcp_pat}"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit -m 'refactor: implement fire-and-forget embedding pattern *)"
    ]
  }
}
