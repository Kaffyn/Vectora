{
  "name": "vectora",
  "displayName": "Vectora AI",
  "description": "Local AI coding assistant — RAG + agentic tools via ACP",
  "version": "0.1.0",
  "publishConfig": {
    "access": "restricted"
  },
  "publisher": "kaffyn",
  "license": "MIT",
  "readme": "README.md",
  "icon": "media/icon.ico",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kaffyn/Vectora.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "rag",
    "agent",
    "local",
    "acp"
  ],
  "activationEvents": [
    "onView:vectora.chatView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vectora.newSession",
        "title": "Vectora: Open Chat",
        "icon": "$(add)"
      },
      {
        "command": "vectora.explainCode",
        "title": "Vectora: Explain Code"
      },
      {
        "command": "vectora.refactorCode",
        "title": "Vectora: Refactor Code"
      },
      {
        "command": "vectora.toggleStatus",
        "title": "Vectora: Start/Stop Core"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vectora-sidebar",
          "title": "Vectora AI",
          "icon": "media/icon.ico"
        }
      ]
    },
    "views": {
      "vectora-sidebar": [
        {
          "type": "webview",
          "id": "vectora.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Vectora",
      "properties": {
        "vectora.corePath": {
          "type": "string",
          "default": "vectora",
          "description": "Path to the Vectora core binary. Use 'vectora' if it's in your PATH."
        },
        "vectora.workspace": {
          "type": "string",
          "description": "Workspace folder for RAG indexing. Defaults to the first workspace folder."
        },
        "vectora.streaming": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming responses from the AI agent."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "vectora.explainCode",
          "group": "vectora@1"
        },
        {
          "command": "vectora.refactorCode",
          "group": "vectora@2"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile-tests": "tsc",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "npm run compile-tests && node ./dist/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "@vscode/vsce": "^2.24.0",
    "@vscode/test-electron": "^2.4.0",
    "mocha": "^10.4.0",
    "@types/mocha": "^10.0.6",
    "glob": "^10.3.12",
    "@types/glob": "^8.1.0"
  }
}
