# ============================================================================
# Vectora Index Service - Environment Configuration
# ============================================================================

# SUPABASE Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-secure-password
SUPABASE_DB_HOST=db.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres

# PostgreSQL DSN (construído a partir dos valores Supabase acima)
# Formato: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:your-secure-password@db.supabase.co:5432/postgres?sslmode=require

# LLM Embedding Provider
EMBEDDING_PROVIDER=gemini  # gemini, openai
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=sk-...

# Server Configuration
GRPC_PORT=3000
GRPC_HOST=0.0.0.0
GRPC_TLS_ENABLED=true
GRPC_TLS_CERT_PATH=/etc/ssl/certs/cert.pem
GRPC_TLS_KEY_PATH=/etc/ssl/private/key.pem

# HTTP Bridge (opcional, para development)
HTTP_BRIDGE_ENABLED=false
HTTP_PORT=8080

# Embedding Configuration
CHUNK_SIZE=512          # Tokens por chunk
CHUNK_OVERLAP=50        # Overlap entre chunks
EMBEDDING_DIMENSION=1536  # Dimensionalidade (Gemini = 1536)

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100    # Requisições por minuto
RATE_LIMIT_UPLOADS=10      # Uploads por hora

# Logging
LOG_LEVEL=info          # debug, info, warn, error
LOG_FORMAT=json         # json, text

# Vercel Deployment
ENVIRONMENT=production  # development, staging, production
NODE_ENV=production

# Optional: Redis para caching (se usar)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Optional: Sentry para error tracking
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENABLED=false
